\fs28 \cf13 \cb11 \strokec13 # Assuming 'cube_matrix' and 'surah_names' (a list of names) are ready\cf9 \strokec9 \
\cf12 \strokec12 def\cf9 \strokec9  \cf22 \cb11 \strokec22 get_recommendation\cf9 \cb11 \strokec9 (surah_num, matrix, surah_names_list):\
    idx = surah_num - \cf16 \strokec16 1\cf9 \strokec9 \
    target = matrix[idx]\
    \
    \cf13 \strokec13 # TensorFlow Euclidean Distance\cf9 \strokec9 \
    distances = tf.norm(matrix - target, axis=\cf16 \strokec16 1\cf9 \strokec9 )\
    \
    \cf13 \strokec13 # Find the top 3 closest neighbors (excluding itself)\cf9 \strokec9 \
    closest_indices = tf.argsort(distances)[\cf16 \strokec16 1\cf9 \strokec9 :\cf16 \strokec16 4\cf9 \strokec9 ]\
    \
    print(\cf14 \strokec14 f"Mathematical Neighbors for \cf7 \strokec7 \{surah_names_list[idx]\}\cf14 \strokec14 :"\cf9 \strokec9 )\
    \cf12 \strokec12 for\cf9 \strokec9  neighbor_idx \cf12 \strokec12 in\cf9 \strokec9  closest_indices.numpy():\
        print(\cf14 \strokec14 f"-> Surah \cf7 \strokec7 \{neighbor_idx + \cf16 \strokec16 1\cf7 \strokec7 \}\cf14 \strokec14 : \cf7 \strokec7 \{surah_names_list[neighbor_idx]\}\cf14 \strokec14 "\cf9 \strokec9 )\
\
