def load_quran_text(filename: str = "data/quran-simple-min.txt") -> Dict[int, List[str]]:
    """Load Quran text and return as {surah: [verses]}"""
    quran_data = {}
    try:
        with open(filename, 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                # Format: "surah:verse|text"
                if ':' in line:
                    parts = line.split(':', 1)
                    if len(parts) == 2:
                        surah_num = int(parts[0])
                        verse_text = parts[1]
                        if surah_num not in quran_data:
                            quran_data[surah_num] = []
                        quran_data[surah_num].append(verse_text)
    except FileNotFoundError:
        # Fallback to sample data
        pass
    return quran_data


def load_quran_uthmani() -> Dict[int, List[str]]:
    """Load Uthmani Quran text (with diacritics)"""
    return load_quran_text("data/quran-uthmani-min.txt")


